    "menus": {
      "view/title": [
        {
          "command": "gemstone.addLogin",
          "when": "view == gemstoneLogins",
          "group": "navigation"
        },
        {
          "command": "gemstone.clearInspector",
          "when": "view == gemstoneInspector",
          "group": "navigation"
        },
        {
          "command": "gemstone.refreshVersions",
          "when": "view == gemstoneVersions",
          "group": "navigation"
        },
        {
          "command": "gemstone.createDatabase",
          "when": "view == gemstoneDatabases",
          "group": "navigation@1"
        },
        {
          "command": "gemstone.refreshDatabases",
          "when": "view == gemstoneDatabases",
          "group": "navigation@2"
        },
        {
          "command": "gemstone.refreshProcesses",
          "when": "view == gemstoneProcesses",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "gemstone.login",
          "when": "view == gemstoneLogins",
          "group": "inline@1"
        },
        {
          "command": "gemstone.editLogin",
          "when": "view == gemstoneLogins",
          "group": "inline@2"
        },
        {
          "command": "gemstone.deleteLogin",
          "when": "view == gemstoneLogins",
          "group": "inline@3"
        },
        {
          "command": "gemstone.duplicateLogin",
          "when": "view == gemstoneLogins"
        },
        {
          "command": "gemstone.sessionCommit",
          "when": "view == gemstoneSessions && viewItem == gemstoneSession",
          "group": "inline@1"
        },
        {
          "command": "gemstone.sessionAbort",
          "when": "view == gemstoneSessions && viewItem == gemstoneSession",
          "group": "inline@2"
        },
        {
          "command": "gemstone.sessionLogout",
          "when": "view == gemstoneSessions && viewItem == gemstoneSession",
          "group": "inline@3"
        },
        {
          "command": "gemstone.openBrowser",
          "when": "view == gemstoneSessions && viewItem == gemstoneSession",
          "group": "inline@4"
        },
        {
          "command": "gemstone.exportClasses",
          "when": "view == gemstoneSessions && viewItem == gemstoneSession"
        },
        {
          "command": "gemstone.selectSession",
          "when": "view == gemstoneSessions && viewItem == gemstoneSession"
        },
        {
          "command": "gemstone.removeInspectorItem",
          "when": "view == gemstoneInspector && viewItem == gemstoneInspectorRoot",
          "group": "inline@1"
        },
        {
          "command": "gemstone.downloadVersion",
          "when": "view == gemstoneVersions && viewItem == gemstoneVersion",
          "group": "inline@1"
        },
        {
          "command": "gemstone.extractVersion",
          "when": "view == gemstoneVersions && viewItem == gemstoneVersionDownloaded",
          "group": "inline@2"
        },
        {
          "command": "gemstone.openVersionFolder",
          "when": "view == gemstoneVersions && viewItem =~ /gemstoneVersion.*Extracted/",
          "group": "inline@3"
        },
        {
          "command": "gemstone.extractVersion",
          "when": "view == gemstoneVersions && viewItem == gemstoneVersionDownloadedExtracted",
          "group": "inline@2"
        },
        {
          "command": "gemstone.deleteDownload",
          "when": "view == gemstoneVersions && viewItem =~ /gemstoneVersion.*Downloaded/"
        },
        {
          "command": "gemstone.deleteExtracted",
          "when": "view == gemstoneVersions && viewItem =~ /gemstoneVersion.*Extracted/"
        },
        {
          "command": "gemstone.replaceExtent",
          "when": "view == gemstoneDatabases && viewItem == gemstoneDbStoneStopped",
          "group": "inline@1"
        },
        {
          "command": "gemstone.startStone",
          "when": "view == gemstoneDatabases && viewItem == gemstoneDbStoneStopped",
          "group": "inline@2"
        },
        {
          "command": "gemstone.stopStone",
          "when": "view == gemstoneDatabases && viewItem == gemstoneDbStoneRunning",
          "group": "inline@1"
        },
        {
          "command": "gemstone.startNetldi",
          "when": "view == gemstoneDatabases && viewItem == gemstoneDbNetldiStopped",
          "group": "inline@1"
        },
        {
          "command": "gemstone.stopNetldi",
          "when": "view == gemstoneDatabases && viewItem == gemstoneDbNetldiRunning",
          "group": "inline@1"
        },
        {
          "command": "gemstone.openDbInFinder",
          "when": "view == gemstoneDatabases && viewItem == gemstoneDb",
          "group": "inline@2"
        },
        {
          "command": "gemstone.openDbTerminal",
          "when": "view == gemstoneDatabases && viewItem == gemstoneDb",
          "group": "inline@3"
        },
        {
          "command": "gemstone.createLoginFromDb",
          "when": "view == gemstoneDatabases && viewItem == gemstoneDb",
          "group": "inline@4"
        },
        {
          "command": "gemstone.deleteDatabase",
          "when": "view == gemstoneDatabases && viewItem == gemstoneDb"
        }
      ],
      "editor/context": [
        {
          "command": "gemstone.displayIt",
          "when": "editorTextFocus && gemstone.hasActiveSession",
          "group": "1_modification@0"
        },
        {
          "command": "gemstone.inspectIt",
          "when": "editorTextFocus && gemstone.hasActiveSession",
          "group": "1_modification@1"
        },
        {
          "command": "gemstone.executeIt",
          "when": "editorTextFocus && gemstone.hasActiveSession",
          "group": "1_modification@2"
        },
        {
          "command": "gemstone.sendersOf",
          "when": "editorTextFocus && gemstone.hasActiveSession",
          "group": "2_navigation@0"
        },
        {
          "command": "gemstone.implementorsOf",
          "when": "editorTextFocus && gemstone.hasActiveSession",
          "group": "2_navigation@1"
        },
        {
          "command": "gemstone.toggleSelectorBreakpoint",
          "when": "editorTextFocus && gemstone.hasActiveSession && resourceScheme == gemstone",
          "group": "3_gemstoneBreakpoints@0"
        }
      ]
    },
    "debuggers": [
      {
        "type": "gemstone",
        "label": "GemStone",
        "languages": [
          "gemstone-smalltalk",
          "gemstone-topaz",
          "gemstone-tonel"
        ],
        "configurationAttributes": {
          "attach": {
            "required": [
              "sessionId",
              "gsProcess"
            ],
            "properties": {
              "sessionId": {
                "type": "number",
                "description": "GCI session ID"
              },
              "gsProcess": {
                "type": "string",
                "description": "GsProcess OOP (bigint as string)"
              },
              "errorMessage": {
                "type": "string",
                "description": "Original error message"
              }
            }
          }
        }
      }
    ],
    "breakpoints": [
      {
        "language": "gemstone-smalltalk"
      }
    ],
    "keybindings": [
      {
        "command": "gemstone.displayIt",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "editorTextFocus && gemstone.hasActiveSession"
      },
      {
        "command": "gemstone.executeIt",
        "key": "ctrl+e",
        "mac": "cmd+e",
        "when": "editorTextFocus && gemstone.hasActiveSession"
      },
      {
        "command": "gemstone.inspectIt",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus && gemstone.hasActiveSession"
      },
      {
        "command": "gemstone.openBrowser",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "gemstone.hasActiveSession"
      }
    ]
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "npm run compile:client && npm run compile:server",
    "compile:client": "tsc -p client/tsconfig.json",
    "compile:server": "tsc -p server/tsconfig.json",
    "bundle": "node esbuild.mjs",
    "watch": "tsc -b -w client/tsconfig.json server/tsconfig.json",
    "test": "npm run test:server && npm run test:client",
    "test:server": "cd server && NODE_OPTIONS=--experimental-require-module npx vitest run",
    "test:client": "cd client && NODE_OPTIONS=--experimental-require-module npx vitest run",
    "test:gci": "cd client && NODE_OPTIONS=--experimental-require-module npx vitest run --config vitest.gci.config.ts",
