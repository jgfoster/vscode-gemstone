{
  "name": "gemstone-ide",
  "displayName": "GemStone Smalltalk IDE",
	"description": "GemStone/S IDE for Visual Studio Code",
  "version": "1.1.1",
  "publisher": "gemtalksystems",
  "license": "MIT",
  "author": "James Foster",
  "homepage": "https://github.com/jgfoster/vscode-gemstone#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/jgfoster/vscode-gemstone"
  },
  "bugs": {
    "url": "https://github.com/jgfoster/vscode-gemstone/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "resources/gemstone-icon.png",
  "categories": [
		"Debuggers",
    "Programming Languages"
  ],
	"keywords": [
		"GemStone",
		"Smalltalk",
		"Database",
		"Object Database",
		"IDE"
	],
  "extensionKind": ["workspace"],
  "activationEvents": [],
  "main": "./client/out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gemstone-topaz",
        "aliases": [
          "GemStone (Topaz)",
          "Topaz"
        ],
        "extensions": [
          ".gs",
          ".tpz"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "gemstone-tonel",
        "aliases": [
          "GemStone (Tonel)",
          "Tonel"
        ],
        "extensions": [
          ".st"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "gemstone-smalltalk",
        "aliases": [
          "GemStone (Smalltalk)",
          "Smalltalk"
        ],
        "mimeTypes": [
          "text/x-gemstone-smalltalk"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gemstone-topaz",
        "scopeName": "source.gemstone-topaz",
        "path": "./syntaxes/gemstone-topaz.tmLanguage.json"
      },
      {
        "language": "gemstone-tonel",
        "scopeName": "source.gemstone-tonel",
        "path": "./syntaxes/gemstone-tonel.tmLanguage.json"
      },
      {
        "language": "gemstone-smalltalk",
        "scopeName": "source.gemstone-smalltalk",
        "path": "./syntaxes/gemstone-smalltalk.tmLanguage.json"
      }
    ],
    "configuration": [
      {
        "title": "GemStone",
        "properties": {
          "gemstone.gciLibraries": {
            "type": "object",
            "default": {},
            "description": "Paths to GCI libraries, keyed by GemStone version (e.g. \"3.7.4.3\": \"/path/to/libgcirpc-3.7.4.3-64.dylib\")",
            "additionalProperties": {
              "type": "string"
            }
          },
          "gemstone.maxEnvironment": {
            "type": "integer",
            "default": 0,
            "minimum": 0,
            "description": "Maximum method dictionary environment to show in the browser (0 = standard Smalltalk only, 2 = show environments 0–2)"
          },
          "gemstone.exportPath": {
            "type": "string",
            "default": "",
            "description": "Root path for exported class files. May be absolute, relative to the workspace root, or use {workspaceRoot} as a variable. Defaults to {workspaceRoot}/gemstone/"
          },
          "gemstone.userManagedDictionaries": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Dictionary names managed by the user. These are never overwritten by export from GemStone. All other dictionaries are exported normally."
          },
          "gemstone.rootPath": {
            "type": "string",
            "default": "~/Documents/GemStone",
            "description": "Root directory for GemStone installations and databases. Supports ~ for home directory."
          },
          "gemstone.logins": {
            "type": "array",
            "default": [],
            "description": "GemStone/S 64 Bit login parameters",
            "items": {
              "type": "object",
              "required": [
                "label"
              ],
              "properties": {
                "label": {
                  "type": "string",
                  "description": "Display name for this login"
                },
                "version": {
                  "type": "string",
                  "description": "GemStone version (e.g. 3.7.2)"
                },
                "gem_host": {
                  "type": "string",
                  "description": "Gem host (e.g. localhost)"
                },
                "stone": {
                  "type": "string",
                  "description": "Stone name (e.g. gs64stone)"
                },
                "gs_user": {
                  "type": "string",
                  "description": "GemStone username (e.g. DataCurator)"
                },
                "gs_password": {
                  "type": "string",
                  "description": "GemStone password"
                },
                "netldi": {
                  "type": "string",
                  "description": "NetLDI name (e.g. gs64ldi)"
                },
                "host_user": {
                  "type": "string",
                  "description": "Host OS username"
                },
                "host_password": {
                  "type": "string",
                  "description": "Host OS password"
                },
                "exportPath": {
                  "type": "string",
                  "description": "Export path template for dictionaries. Variables: {workspaceRoot}, {host}, {stone}, {user}, {index}, {dictName}. Default: {workspaceRoot}/gemstone/{host}/{stone}/{user}/{index}-{dictName}"
                }
              }
            }
          }
        }
      },
      {
        "title": "GemStone Smalltalk Formatter",
        "properties": {
          "gemstoneSmalltalk.formatter.spacesInsideParens": {
            "type": "boolean",
            "default": false,
            "description": "Add spaces inside parentheses: ( x ) instead of (x)"
          },
          "gemstoneSmalltalk.formatter.spacesInsideBrackets": {
            "type": "boolean",
            "default": false,
            "description": "Add spaces inside brackets: [ x ] instead of [x]"
          },
          "gemstoneSmalltalk.formatter.spacesInsideBraces": {
            "type": "boolean",
            "default": false,
            "description": "Add spaces inside braces: { x } instead of {x}"
          },
          "gemstoneSmalltalk.formatter.spacesAroundAssignment": {
            "type": "boolean",
            "default": true,
            "description": "Add spaces around the assignment operator: x := y instead of x:=y"
          },
          "gemstoneSmalltalk.formatter.spacesAroundBinarySelectors": {
            "type": "boolean",
            "default": true,
            "description": "Add spaces around binary selectors: a + b instead of a+b"
          },
          "gemstoneSmalltalk.formatter.spaceAfterCaret": {
            "type": "boolean",
            "default": false,
            "description": "Add space after return caret: ^ x instead of ^x"
          },
          "gemstoneSmalltalk.formatter.blankLineAfterMethodPattern": {
            "type": "boolean",
            "default": true,
            "description": "Insert a blank line between the method pattern and body"
          },
          "gemstoneSmalltalk.formatter.maxLineLength": {
            "type": "number",
            "default": 0,
            "minimum": 0,
            "description": "Maximum line length for wrapping (0 = no wrapping)"
          },
          "gemstoneSmalltalk.formatter.continuationIndent": {
            "type": "number",
            "default": 2,
            "minimum": 1,
            "maximum": 8,
            "description": "Additional indentation for continuation lines (multi-keyword messages)"
          },
          "gemstoneSmalltalk.formatter.multiKeywordThreshold": {
            "type": "number",
            "default": 2,
            "minimum": 2,
            "maximum": 10,
            "description": "Split keyword messages to multiple lines when keyword count reaches this threshold"
          },
          "gemstoneSmalltalk.formatter.removeUnnecessaryParens": {
            "type": "boolean",
            "default": true,
            "description": "Remove unnecessary parentheses based on Smalltalk message precedence (unary > binary > keyword, left-to-right)"
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gemstone",
          "title": "GemStone",
          "icon": "resources/gemstone-sidebar.png"
        }
      ]
    },
    "views": {
      "gemstone": [
        {
          "id": "gemstoneSharedMemory",
          "name": "Configure OS",
          "type": "tree",
          "when": "isMac || isLinux",
          "visibility": "collapsed"
        },
        {
          "id": "gemstoneVersions",
          "name": "Versions",
          "type": "tree"
        },
        {
          "id": "gemstoneDatabases",
          "name": "Databases",
          "type": "tree"
        },
        {
          "id": "gemstoneProcesses",
          "name": "Processes",
          "type": "tree"
        },
        {
          "id": "gemstoneLogins",
          "name": "Logins",
          "type": "tree",
          "icon": "$(key)"
        },
        {
          "id": "gemstoneSessions",
          "name": "Sessions",
          "type": "tree",
          "icon": "$(plug)"
        },
        {
          "id": "gemstoneInspector",
          "name": "Inspector",
          "type": "tree",
          "icon": "$(eye)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "gemstoneInspector",
        "contents": "No objects inspected yet.\nSelect code and press Cmd+I to inspect."
      },
      {
        "view": "gemstoneVersions",
        "contents": "Loading versions...\n[Refresh](command:gemstone.refreshVersions)"
      },
      {
        "view": "gemstoneDatabases",
        "contents": "No databases found.\n[Create Database](command:gemstone.createDatabase)"
      },
      {
        "view": "gemstoneProcesses",
        "contents": "No running GemStone processes.\n[Refresh](command:gemstone.refreshProcesses)"
      }
    ],
    "commands": [
      {
        "command": "gemstone.addLogin",
        "title": "Add Login",
        "category": "GemStone",
        "icon": "$(add)"
      },
      {
        "command": "gemstone.editLogin",
        "title": "Edit Login",
        "category": "GemStone",
        "icon": "$(edit)"
      },
      {
        "command": "gemstone.deleteLogin",
        "title": "Delete Login",
        "category": "GemStone",
        "icon": "$(trash)"
      },
      {
        "command": "gemstone.duplicateLogin",
        "title": "Duplicate Login",
        "category": "GemStone",
        "icon": "$(copy)"
      },
      {
        "command": "gemstone.login",
        "title": "Login",
        "category": "GemStone",
        "icon": "$(plug)"
      },
      {
        "command": "gemstone.sessionCommit",
        "title": "Commit",
        "category": "GemStone",
        "icon": "$(check)"
      },
      {
        "command": "gemstone.sessionAbort",
        "title": "Abort",
        "category": "GemStone",
        "icon": "$(discard)"
      },
      {
        "command": "gemstone.sessionLogout",
        "title": "Logout",
        "category": "GemStone",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "gemstone.selectSession",
        "title": "Select as Active Session",
        "category": "GemStone",
        "icon": "$(target)"
      },
      {
        "command": "gemstone.exportClasses",
        "title": "Export Classes to Files",
        "category": "GemStone",
        "icon": "$(cloud-download)"
      },
      {
        "command": "gemstone.displayIt",
        "title": "Display It",
        "category": "GemStone",
        "icon": "$(play)"
      },
      {
        "command": "gemstone.executeIt",
        "title": "Execute It",
        "category": "GemStone",
        "icon": "$(run)"
      },
      {
        "command": "gemstone.inspectIt",
        "title": "Inspect It",
        "category": "GemStone",
        "icon": "$(eye)"
      },
      {
        "command": "gemstone.showTranscript",
        "title": "Show Transcript",
        "category": "GemStone",
        "icon": "$(output)"
      },
      {
        "command": "gemstone.removeInspectorItem",
        "title": "Remove",
        "category": "GemStone",
        "icon": "$(close)"
      },
      {
        "command": "gemstone.clearInspector",
        "title": "Clear All",
        "category": "GemStone",
        "icon": "$(clear-all)"
      },
      {
        "command": "gemstone.openBrowser",
        "title": "Open System Browser",
        "category": "GemStone",
        "icon": "$(list-tree)"
      },
      {
        "command": "gemstone.refreshBrowser",
        "title": "Refresh Browser",
        "category": "GemStone",
        "icon": "$(refresh)"
      },
      {
        "command": "gemstone.refreshTests",
        "title": "Refresh SUnit Tests",
        "category": "GemStone",
